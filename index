function saveCompany() {
  const idx = parseInt(document.getElementById('editIndex').value);
  const { lat, lng } = parseCoordinates(document.getElementById('coords').value);
  const data = { name: document.getElementById('name').value.trim(), address: document.getElementById('address').value.trim(), lat, lng, logo: document.getElementById('logo').value.trim() || fallbackIcon, website: document.getElementById('website').value.trim(), linkedin: document.getElementById('linkedin').value.trim() };
  if (!data.name || isNaN(lat) || isNaN(lng)) { showToast("Name and coordinates are required"); return; }
  if (idx !== -1) { const oldKey = companyKey(companies[idx]); if (markersMap.has(oldKey)) { markerCluster.removeLayer(markersMap.get(oldKey)); markersMap.delete(oldKey); } companies[idx] = data; showToast("Company updated!"); }
  else { companies.push(data); showToast("Company pinned to map!"); }
  const { lat: savedLat, lng: savedLng, name: savedName } = data;
  closeModal(); localStorage.setItem("blr_tech_atlas_v2", JSON.stringify(companies)); render(); pushToGist();
  map.setView([savedLat, savedLng], 15, { animate: true });
  setTimeout(() => { markerCluster.eachLayer(marker => { const ll = marker.getLatLng(); if (Math.abs(ll.lat-savedLat)<0.0001 && Math.abs(ll.lng-savedLng)<0.0001) marker.openPopup(); }); }, 300);
  document.querySelectorAll('.company-item').forEach(el => { const n = el.querySelector('.company-name'); if (n && n.textContent === savedName) { el.classList.add('active'); el.scrollIntoView({ behavior:'smooth', block:'nearest' }); } });
}

