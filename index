<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bangalore Tech Atlas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
<style>
  :root {
    --bg:        #f4f6fb;
    --surface:   #ffffff;
    --surface2:  #f0f3fa;
    --surface3:  #e8edf7;
    --border:    rgba(30,60,140,0.08);
    --border2:   rgba(30,60,140,0.14);
    --accent:    #2563eb;
    --accent2:   #0ea5e9;
    --accent-glow: rgba(37,99,235,0.15);
    --accent2-glow: rgba(14,165,233,0.12);
    --text:      #0f172a;
    --text2:     #4b5a7a;
    --text3:     #94a3b8;
    --danger:    #ef4444;
    --danger-bg: rgba(239,68,68,0.08);
    --sidebar-w: 440px;
    --radius:    14px;
    --radius-sm: 9px;
    --toggle-size: 28px;
    --toolbar-height: 40px;
  }
  body.dark {
    --bg:        #0b1220;
    --surface:   #111827;
    --surface2:  #1f2937;
    --surface3:  #374151;
    --border:    rgba(255,255,255,0.06);
    --border2:   rgba(255,255,255,0.12);
    --text:      #e5e7eb;
    --text2:     #9ca3af;
    --text3:     #6b7280;
    --accent:    #3b82f6;
    --accent2:   #22c55e;
    --accent-glow: rgba(59,130,246,0.2);
    --accent2-glow: rgba(34,197,94,0.2);
    --danger:    #ef4444;
    --danger-bg: rgba(239,68,68,0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Instrument Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  /* ─── SIDEBAR ─── */
  #sidebar {
    width: var(--sidebar-w);
    min-width: 260px;
    max-width: 600px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    z-index: 1000;
    flex-shrink: 0;
    position: relative;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1), min-width 0.3s cubic-bezier(0.4,0,0.2,1), border-color 0.3s;
    overflow: visible;
  }
  #sidebar.collapsed { width: 0 !important; min-width: 0 !important; border-right-color: transparent; }
  #sidebar.collapsed .sidebar-header,
  #sidebar.collapsed .search-wrap,
  #sidebar.collapsed #companyList { opacity: 0; pointer-events: none; transition: opacity 0.15s; }
  #sidebar::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.015'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }
  #sidebarToggleBtn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    right: calc(-1 * var(--toggle-size) / 2 - 1px);
    z-index: 1200;
    width: var(--toggle-size);
    height: var(--toggle-size);
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border2);
    box-shadow: 0 2px 8px rgba(30,60,140,0.12), 0 0 0 3px var(--bg);
    color: var(--text3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  #sidebarToggleBtn:hover { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 4px 16px rgba(37,99,235,0.35), 0 0 0 3px var(--bg); transform: translateY(-50%) scale(1.1); }
  #sidebarToggleBtn:active { transform: translateY(-50%) scale(0.95); }
  #sidebar.collapsed #sidebarToggleBtn { right: calc(-1 * var(--toggle-size) - 8px); background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 4px 20px rgba(37,99,235,0.4), 0 0 0 3px var(--bg); }
  #sidebarToggleBtn svg { width: 12px; height: 12px; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; fill: none; flex-shrink: 0; transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); }
  #sidebar.collapsed #sidebarToggleBtn svg { transform: rotate(180deg); }

  .sidebar-header {
    padding: 28px 22px 20px;
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
    background: linear-gradient(160deg, rgba(37,99,235,0.05) 0%, transparent 60%);
  }
  .header-eyebrow { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent2); box-shadow: 0 0 6px var(--accent2); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
  .eyebrow-text { font-size: 10px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--accent2); }
  .sidebar-header h1 { font-family: 'Cabinet Grotesk', sans-serif; font-size: 26px; font-weight: 900; letter-spacing: -0.5px; line-height: 1.1; color: var(--text); }
  .sidebar-header h1 span { background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .header-meta { display: flex; align-items: center; gap: 10px; margin-top: 14px; }
  .count-badge { display: inline-flex; align-items: center; gap: 5px; background: rgba(37,99,235,0.08); border: 1px solid rgba(37,99,235,0.18); color: var(--accent); font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; }
  .count-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }

  /* ══════════════════════════════════════════
     SMOOTH THEME TOGGLE — PILL SWITCH
  ══════════════════════════════════════════ */
  .theme-toggle-wrap {
    position: absolute;
    top: 24px;
    right: 22px;
  }

  /* Hidden checkbox drives the toggle */
  #themeCheckbox { display: none; }

  .theme-pill {
    display: flex;
    align-items: center;
    width: 60px;
    height: 30px;
    border-radius: 999px;
    background: #dde5f4;
    border: 1.5px solid rgba(30,60,140,0.14);
    cursor: pointer;
    position: relative;
    padding: 3px;
    transition:
      background  0.4s cubic-bezier(0.4,0,0.2,1),
      border-color 0.4s cubic-bezier(0.4,0,0.2,1),
      box-shadow  0.4s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 1px 4px rgba(30,60,140,0.10), inset 0 1px 2px rgba(255,255,255,0.5);
    outline: none;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .theme-pill:focus-visible {
    box-shadow: 0 0 0 3px rgba(37,99,235,0.3);
  }

  /* Dark state */
  body.dark .theme-pill {
    background: #1e2d4a;
    border-color: rgba(255,255,255,0.10);
    box-shadow: 0 1px 4px rgba(0,0,0,0.3), inset 0 1px 2px rgba(255,255,255,0.04);
  }

  /* The sliding knob */
  .theme-knob {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 6px rgba(30,60,140,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: translateX(0);
    transition:
      transform 0.4s cubic-bezier(0.34,1.56,0.64,1),
      background 0.4s cubic-bezier(0.4,0,0.2,1),
      box-shadow 0.4s cubic-bezier(0.4,0,0.2,1);
    will-change: transform;
    flex-shrink: 0;
  }
  .leaflet-popup-close-button {
  top: 6px !important;
  right: 6px !important;
  background: rgba(0,0,0,0.4);
  border-radius: 50%;
  width: 26px;
  height: 26px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white !important;
}

  body.dark .theme-knob {
    transform: translateX(28px);
    background: #3b82f6;
    box-shadow: 0 2px 8px rgba(59,130,246,0.5);
  }

  /* Icons inside knob */
  .knob-sun,
  .knob-moon {
    position: absolute;
    width: 13px;
    height: 13px;
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.4,0,0.2,1);
  }

  /* Sun visible in light mode */
  .knob-sun  { opacity: 1;  transform: scale(1) rotate(0deg);   }
  .knob-moon { opacity: 0;  transform: scale(0.6) rotate(40deg); }

  body.dark .knob-sun  { opacity: 0;  transform: scale(0.6) rotate(-40deg); }
  body.dark .knob-moon { opacity: 1;  transform: scale(1) rotate(0deg);     }

  /* Tiny icon labels on the pill track */
  .pill-track-icons {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 7px;
    pointer-events: none;
  }
  .pill-track-icon {
    width: 11px;
    height: 11px;
    opacity: 0.35;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }
  /* Dim the icon that's currently "active" (hidden behind knob) */
  body:not(.dark) .pill-track-icon--sun  { opacity: 0.1; }
  body.dark       .pill-track-icon--moon { opacity: 0.1; }

  .search-wrap { padding: 14px 16px; border-bottom: 1px solid var(--border); position: relative; z-index: 1; }
  .toolbar { display: flex; align-items: center; gap: 8px; flex-wrap: nowrap; }
  .search-box { flex: 1; min-width: 0; position: relative; display: flex; align-items: center; }
  .search-box svg { position: absolute; left: 10px; width: 16px; height: 16px; color: var(--text3); pointer-events: none; }
  .search-box input { height: var(--toolbar-height); width: 100%; padding-left: 36px; padding-right: 12px; background: var(--surface2); border: 1px solid var(--border2); border-radius: var(--radius-sm); font-family: inherit; font-size: 13px; color: var(--text); outline: none; }
  .search-box input::placeholder { color: var(--text3); }
  .search-box input:focus { border-color: rgba(37,99,235,0.35); background: var(--surface3); }
  .search-box input.has-value { padding-right: 34px; }
  .search-clear { position: absolute; right: 9px; width: 20px; height: 20px; border-radius: 0; background: transparent; border: none; cursor: pointer; display: none; align-items: center; justify-content: center; padding: 0; flex-shrink: 0; opacity: 0.45; }
  .search-clear svg { width: 11px; height: 11px; stroke: var(--text); stroke-width: 2.5; stroke-linecap: round; }
  .search-clear:hover { opacity: 1; }
  .search-clear.visible { display: flex; }
  .toolbar-btn { height: 38px; border: none; border-radius: var(--radius-sm); cursor: pointer; font-family: 'Cabinet Grotesk', sans-serif; font-weight: 700; font-size: 13px; transition: all 0.18s; display: flex; align-items: center; justify-content: center; gap: 5px; }
  .btn-add-main { width: 38px; background: var(--accent); color: #fff; font-size: 20px; box-shadow: 0 4px 18px rgba(37,99,235,0.25); flex-shrink: 0; }
  .btn-add-main:hover { background: #8078ff; box-shadow: 0 6px 22px rgba(37,99,235,0.35); transform: translateY(-1px); }
  select#sortOption { height: var(--toolbar-height); padding: 0 10px; border-radius: var(--radius-sm); border: 1px solid var(--border2); background: var(--surface2); color: var(--text2); font-family: inherit; font-size: 12px; cursor: pointer; outline: none; flex-shrink: 0; }
  select#sortOption:hover, select#sortOption:focus { border-color: rgba(37,99,235,0.35); background: var(--surface3); color: var(--text); }

  #companyList { flex: 1; overflow-y: auto; padding: 10px 12px; position: relative; z-index: 1; }
  #companyList::-webkit-scrollbar { width: 8px; }
  #companyList::-webkit-scrollbar-track { background: transparent; }
  #companyList::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 8px; }
  #companyList::-webkit-scrollbar-thumb:hover { background: var(--border2); }

  .company-item { display: flex; flex-direction: column; padding: 0; border-radius: var(--radius); cursor: pointer; transition: all 0.2s ease; margin-bottom: 8px; border: 1px solid rgba(0,0,0,0.75); position: relative; background: var(--surface); box-shadow: 0 1px 4px rgba(0,0,0,0.08); overflow: hidden; }
  .company-item.is-new { animation: slideIn 0.3s ease both; }
  @keyframes slideIn { from { opacity: 0; transform: translateX(-8px); } to { opacity: 1; transform: translateX(0); } }
  .company-item:hover { border-color: rgba(0,0,0,0.85); box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-1px); }
  .company-item.active { border-color: rgba(0,0,0,0.85); background: rgba(37,99,235,0.02); box-shadow: 0 4px 16px rgba(37,99,235,0.12); }
  .company-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--card-accent, var(--accent)); }

  .card-top { display: flex; align-items: center; gap: 12px; padding: 12px 12px 10px; }
  .company-avatar { width: 44px; height: 44px; border-radius: 11px; background: var(--surface3); border: 1px solid var(--border2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
  .company-avatar img { width: 28px; height: 28px; object-fit: contain; border-radius: 4px; }
  .company-info { flex: 1; min-width: 0; }
  .company-name { font-family: 'Cabinet Grotesk', sans-serif; font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .company-address { font-size: 11px; color: var(--text3); line-height: 1.35; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .item-actions { display: flex; gap: 4px; flex-shrink: 0; align-self: flex-start; opacity: 0; visibility: hidden; transform: translateY(-4px); transition: all 0.2s ease; }
  .company-item:hover .item-actions { opacity: 1; visibility: visible; transform: translateY(0); transition-delay: 0.05s; }
  .action-btn { width: 28px; height: 28px; border-radius: 7px; border: none; cursor: pointer; transition: all 0.15s; display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding: 0; }
  .action-btn svg { width: 13px; height: 13px; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; fill: none; flex-shrink: 0; }
  .btn-edit { background: rgba(37,99,235,0.08); color: #2563eb; border: 1px solid rgba(37,99,235,0.18); }
  .btn-edit:hover { background: rgba(37,99,235,0.18); color: #1d4ed8; transform: scale(1.08); }
  .btn-del { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
  .btn-del:hover { background: rgba(239,68,68,0.15); transform: scale(1.08); }

  .card-footer { display: flex; border-top: 1px solid rgba(0,0,0,0.08); }
  .card-link { flex: 1; display: flex; align-items: center; justify-content: center; gap: 5px; padding: 8px 6px; font-size: 11px; font-weight: 600; color: var(--text2); text-decoration: none; background: transparent; transition: all 0.15s; cursor: pointer; font-family: inherit; border: none; }
  .card-link + .card-link { border-left: 1px solid rgba(0,0,0,0.08); }
  .card-link:hover { background: rgba(0,0,0,0.05); color: var(--card-accent, var(--accent)); }
  .card-link svg { flex-shrink: 0; opacity: 0.65; transition: opacity 0.15s; }
  .card-link:hover svg { opacity: 1; }

  .empty-state { padding: 40px 20px; text-align: center; color: var(--text3); }
  .empty-state .empty-icon { font-size: 36px; margin-bottom: 12px; opacity: 0.4; }
  .empty-state p { font-size: 13px; line-height: 1.5; }

  #map { flex: 1; background: #e8edf5; }

  .leaflet-popup-content-wrapper { background: var(--surface) !important; border: 1px solid var(--border2) !important; border-radius: var(--radius) !important; box-shadow: 0 8px 30px rgba(30,60,140,0.12) !important; color: var(--text) !important; }
  .leaflet-popup-tip { background: var(--surface) !important; }
  .popup-inner { padding: 4px 2px; min-width: 180px; }
  .popup-company-name { font-family: 'Cabinet Grotesk', sans-serif; font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 4px; }
  .popup-addr { font-size: 11px; color: var(--text3); margin: 0 0 10px; line-height: 1.4; }
  .popup-link { display: inline-flex; align-items: center; gap: 4px; font-size: 11.5px; font-weight: 600; color: var(--accent2); text-decoration: none; padding: 5px 10px; border-radius: 6px; background: var(--accent2-glow); border: 1px solid rgba(0,212,170,0.2); transition: all 0.15s; }
  .popup-link:hover { background: rgba(0,212,170,0.2); color: #00e8bc; }

  .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .modal-content { background: var(--surface); width: 420px; max-width: 92%; margin: 60px auto; padding: 28px; border-radius: 18px; border: 1px solid var(--border2); box-shadow: 0 20px 60px rgba(30,60,140,0.12), 0 0 0 1px rgba(30,60,140,0.06); animation: modalIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes modalIn { from { transform: translateY(-24px) scale(0.97); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
  .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22px; }
  .modal-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 18px; font-weight: 800; color: var(--text); }
  .close-btn { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: var(--surface2); border: 1px solid var(--border); color: var(--text2); font-size: 16px; transition: all 0.15s; }
  .close-btn:hover { background: var(--surface3); color: var(--text); }
  .form-row { margin-bottom: 14px; }
  .form-label { font-size: 10px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; display: block; }
  .form-input { width: 100%; background: var(--surface2); border: 1px solid var(--border2); border-radius: var(--radius-sm); padding: 10px 13px; font-family: inherit; font-size: 13.5px; color: var(--text); outline: none; transition: all 0.2s; }
  .form-input::placeholder { color: var(--text3); }
  .form-input:focus { border-color: rgba(37,99,235,0.4); background: var(--surface3); box-shadow: 0 0 0 3px rgba(37,99,235,0.08); }
  .form-divider { height: 1px; background: var(--border); margin: 16px 0; }
  #companyModal .btn-save { width: 100%; padding: 13px; background: linear-gradient(135deg, var(--accent), #1d4ed8); color: #fff; border: none; border-radius: var(--radius-sm); font-family: 'Cabinet Grotesk', sans-serif; font-weight: 800; font-size: 14px; cursor: pointer; box-shadow: 0 6px 20px rgba(37,99,235,0.25); transition: all 0.2s; }
  #companyModal .btn-save:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(37,99,235,0.35); }
  #gistModal .btn-save { width: 100%; padding: 13px; background: linear-gradient(135deg, var(--accent), #1d4ed8); color: #fff; border: none; border-radius: var(--radius-sm); font-family: 'Cabinet Grotesk', sans-serif; font-weight: 800; font-size: 14px; cursor: pointer; box-shadow: 0 6px 20px rgba(37,99,235,0.25); transition: all 0.2s; flex: 1; }
  #gistModal .btn-save:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(37,99,235,0.35); }

  #toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--surface2); color: var(--text); padding: 10px 20px 10px 14px; border-radius: 50px; font-size: 13px; font-weight: 500; z-index: 10000; display: none; border: 1px solid var(--border2); box-shadow: 0 4px 20px rgba(30,60,140,0.1); white-space: nowrap; align-items: center; gap: 8px; animation: toastIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes toastIn { from { opacity: 0; transform: translateX(-50%) translateY(20px); } to { opacity: 1; transform: translateX(-50%) translateY(0); } }
  .toast-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent2); box-shadow: 0 0 6px var(--accent2); flex-shrink: 0; }

  #resizer { width: 5px; cursor: col-resize; background: transparent; position: absolute; right: 0; top: 0; bottom: 0; z-index: 10; transition: background 0.2s; }
  #resizer:hover { background: rgba(37,99,235,0.2); }

  .company-marker-wrap { border: 2.5px solid rgba(255,255,255,0.9); box-shadow: 0 4px 14px rgba(0,0,0,0.12), 0 0 0 1px rgba(37,99,235,0.2); overflow: hidden; background: #f0f3fa; display: flex; align-items: center; justify-content: center; }
  .marker-square    { width: 38px; height: 38px; border-radius: 8px; }
  .marker-rectangle { width: 48px; height: 32px; border-radius: 6px; }
  .marker-circle    { width: 38px; height: 38px; border-radius: 50%; }
  .company-marker-wrap img { width: 100%; height: 100%; object-fit: contain; }

  .list-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--text3); padding: 6px 4px 8px; display: flex; align-items: center; gap: 8px; }
  .list-section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  #mapMenu { position: absolute; top: 16px; right: 16px; z-index: 900; }
