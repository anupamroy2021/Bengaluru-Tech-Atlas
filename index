async function saveGistCredentials() {
  const token = document.getElementById('gistToken').value.trim();
  const id = document.getElementById('gistId').value.trim();
  const info = document.getElementById('gistInfo');
  if (!token) { showToast("Token is required"); return; }
  info.style.display = 'block'; info.textContent = 'Connecting…';
  try {
    let gistId = id;
    if (!gistId) {
      // No ID provided → create a new Gist with current local data
      const res = await fetch('https://api.github.com/gists', { method:'POST', headers:{'Authorization':`token ${token}`,'Content-Type':'application/json'}, body: JSON.stringify({ description:'Bengaluru Tech Atlas Data', public:false, files:{'atlas.json':{content:JSON.stringify(companies,null,2)}} }) });
      if (!res.ok) throw new Error(`GitHub API error: ${res.status}`);
      const data = await res.json();
      gistId = data.id;
      info.innerHTML = `✅ Created new Gist!<br><strong>ID:</strong> <code style="font-size:10px;word-break:break-all;">${gistId}</code>`;
      localStorage.setItem('gist_token', token); localStorage.setItem('gist_id', gistId);
      document.getElementById('gistId').value = gistId;
      updateGistStatusDot(); showToast("Gist created & connected!");
    } else {
      // ID provided → verify it exists, then PULL from remote (don't overwrite)
      const res = await fetch(`https://api.github.com/gists/${gistId}`, { headers: { 'Authorization': `token ${token}` } });
      if (!res.ok) throw new Error(`Gist not found: ${res.status}`);
      const data = await res.json();
      const content = data.files['atlas.json']?.content;
      localStorage.setItem('gist_token', token); localStorage.setItem('gist_id', gistId);
      document.getElementById('gistId').value = gistId;
      updateGistStatusDot();
      if (content) {
        // Remote has data → pull it in
        companies = JSON.parse(content);
        markersMap.forEach(m => markerCluster.removeLayer(m)); markersMap.clear();
        localStorage.setItem("blr_tech_atlas_v2", JSON.stringify(companies));
        render();
        info.innerHTML = `✅ Connected & synced from Gist!<br><strong>ID:</strong> <code style="font-size:10px;word-break:break-all;">${gistId}</code>`;
        showToast("Connected & synced from Gist!");
      } else {
        // Remote Gist exists but no atlas.json yet → push local data to it
        await pushToGist();
        info.innerHTML = `✅ Connected!<br><strong>ID:</strong> <code style="font-size:10px;word-break:break-all;">${gistId}</code>`;
        showToast("Gist connected!");
      }
    }
  } catch (err) { info.style.display = 'block'; info.textContent = '❌ Error: ' + err.message; }
}

function clearGistCredentials() { localStorage.removeItem('gist_token'); localStorage.removeItem('gist_id'); document.getElementById('gistToken').value = ''; document.getElementById('gistId').value = ''; document.getElementById('gistInfo').style.display = 'none'; updateGistStatusDot(); showToast("Gist credentials cleared"); }
async function pushToGist() { const { token, id } = getGistCreds(); if (!token || !id) return; try { const res = await fetch(`https://api.github.com/gists/${id}`, { method:'PATCH', headers:{'Authorization':`token ${token}`,'Content-Type':'application/json'}, body:JSON.stringify({files:{'atlas.json':{content:JSON.stringify(companies,null,2)}}}) }); if (!res.ok) throw new Error(`Push failed: ${res.status}`); } catch(e) { showToast("⚠️ Gist sync failed: " + e.message); } }
async function syncFromGist() {
  const { token, id } = getGistCreds();
  if (!token || !id) { openGistModal(); showToast("Set up Gist credentials first"); return; }
  showToast("Syncing from Gist…");
  try {
    const res = await fetch(`https://api.github.com/gists/${id}`, { headers: { 'Authorization': `token ${token}` } });
    if (!res.ok) throw new Error(`${res.status}`);
    const data = await res.json();
    const content = data.files['atlas.json']?.content;
    if (!content) throw new Error("atlas.json not found in Gist");
    companies = JSON.parse(content);
    markersMap.forEach(m => markerCluster.removeLayer(m)); markersMap.clear();
    localStorage.setItem("blr_tech_atlas_v2", JSON.stringify(companies));
    render(); showToast("Synced from Gist!");
  } catch(err) { showToast("Sync failed: " + err.message); }
}

updateGistStatusDot();

document.addEventListener('keydown', (e) => {
  const tag = document.activeElement.tagName.toLowerCase();
  const isTyping = tag === 'input' || tag === 'textarea' || tag === 'select';
  if (e.key === 'Escape') { closeModal(); closeGistModal(); closeMapMenu(); return; }
  if (isTyping) return;
  if (e.key === 'n' || e.key === 'N') { e.preventDefault(); openModal(); return; }
  if (e.key === '/') { e.preventDefault(); document.getElementById('search').focus(); return; }
});

function triggerImport() { document.getElementById('importFileInput').click(); }
function handleImport(event) {
  const file = event.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const parsed = JSON.parse(e.target.result);
      if (!Array.isArray(parsed)) throw new Error("Expected a JSON array");
      const valid = parsed.filter(c => c.name && !isNaN(c.lat) && !isNaN(c.lng));
      if (valid.length === 0) throw new Error("No valid company entries found");
      const added = valid.filter(imp => !companies.some(c => c.name === imp.name && c.lat === imp.lat && c.lng === imp.lng));
      companies.push(...added); render(); pushToGist(); showToast(`Imported ${added.length} of ${valid.length} companies`);
    } catch(err) { showToast("Import failed: " + err.message); }
    event.target.value = '';
  };
  reader.readAsText(file);
}

async function exportPDF() {
  try {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation:"p", unit:"mm", format:"a4" });
    const sortedCompanies = [...companies].sort((a,b) => a.name.localeCompare(b.name));
    const columns = [{ header:"Company", dataKey:"name" },{ header:"Address", dataKey:"address" },{ header:"Coordinates", dataKey:"coords" },{ header:"Website", dataKey:"website" }];
    const rows = sortedCompanies.map(c => ({ name:c.name||"", address:c.address||"", coords:(c.lat&&c.lng)?`${c.lat}, ${c.lng}`:"", website:c.website||"" }));
    doc.setFillColor(37,99,235); doc.rect(0,0,210,20,"F");
    doc.setTextColor(255); doc.setFontSize(14); doc.setFont("Helvetica","bold");
    doc.text("Bengaluru Tech Atlas", 14, 13);
    doc.setFontSize(9); doc.text(new Date().toLocaleDateString(), 160, 13);
    doc.setTextColor(0);
    doc.autoTable({ startY:22, columns, body:rows, styles:{fontSize:8,cellPadding:3,overflow:"linebreak",valign:"middle",textColor:[0,0,0]}, headStyles:{fillColor:[37,99,235],textColor:255,fontStyle:"bold"}, alternateRowStyles:{fillColor:[245,247,252]}, columnStyles:{name:{cellWidth:40,fontStyle:"bold"},address:{cellWidth:70},coords:{cellWidth:40},website:{cellWidth:40}}, didDrawCell:function(data){if(data.section!=="body")return;const row=data.row.raw;if(data.column.dataKey==="coords"&&row.coords)doc.link(data.cell.x,data.cell.y,data.cell.width,data.cell.height,{url:`https://www.google.com/maps?q=${row.coords}`});if(data.column.dataKey==="website"&&row.website){const u=row.website.startsWith("http")?row.website:"https://"+row.website;doc.link(data.cell.x,data.cell.y,data.cell.width,data.cell.height,{url:u});}}, didDrawPage:function(){const ph=doc.internal.pageSize.height;doc.setFontSize(8);doc.setTextColor(150);doc.text(`Page ${doc.internal.getNumberOfPages()}`,170,ph-10);} });
    doc.save("bengaluru-tech-atlas.pdf");
  } catch (err) { console.error(err); alert("PDF generation failed: " + err.message); }
}

(function() {
  const si = document.getElementById('search');
  const sc = document.getElementById('searchClear');
  if (si && sc) {
    si.addEventListener('input', function() {
      const has = si.value.length > 0;
      sc.classList.toggle('visible', has);
      si.style.paddingRight = has ? '34px' : '12px';
    });
  }
})();

function clearSearch() {
  const searchInput = document.getElementById('search');
  const searchClear = document.getElementById('searchClear');
  searchInput.value = '';
  searchClear.classList.remove('visible');
  searchInput.classList.remove('has-value');
  searchInput.focus();
  render('');
}

