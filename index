function parseCoordinates(input) {
  if (!input) return { lat: NaN, lng: NaN };
  input = input.trim();
  if (input.includes(',') && !input.includes('http')) { const parts = input.split(',').map(x => x.trim()); return { lat: parseFloat(parts[0]), lng: parseFloat(parts[1]) }; }
  let match = input.match(/@(-?\d+\.\d+),\s*(-?\d+\.\d+)/);
  if (match) return { lat: parseFloat(match[1]), lng: parseFloat(match[2]) };
  match = input.match(/[?&]q=(-?\d+\.\d+),\s*(-?\d+\.\d+)/);
  if (match) return { lat: parseFloat(match[1]), lng: parseFloat(match[2]) };
  return { lat: NaN, lng: NaN };
}

function getImageShape(url) {
  return new Promise((resolve) => {
    const img = new Image();
    img.onload = () => { const r = img.width / img.height; if (Math.abs(r-1)<0.1) resolve("marker-square"); else if (r>1.2) resolve("marker-rectangle"); else resolve("marker-circle"); };
    img.onerror = () => resolve("marker-circle");
    img.src = url;
  });
}

